	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "dotenv -e .env -- vite dev --host --port ${PORT:-3000}",
		"build": "dotenv -e .env -- vite build",
		"preview": "dotenv -e .env -- vite preview --host --port ${PORT:-3000}",
		"auth:generate": "ENV=auth npx @better-auth/cli@latest generate --output schemas/auth.js",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"test": "npm run test:unit -- --run",
		"test:unit": "vitest",
		"prepare": "svelte-kit sync || echo ''",
		"check": "echo 'typecheck disabled'",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write ."
	},
